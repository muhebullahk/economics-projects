xlim=c(0, 520), ylim=c(0, 55),
main="Competitive Labour Market: Worker & Firm Surplus (Before/After Demand Shift)")
# Demand curves
lines(Nd0, W, lwd=2)
lines(Nd1, W, lwd=2, lty=2)
# ---------------------------------------------------------
# Shade SURPLUSES BEFORE demand shift (D)
# ---------------------------------------------------------
N_grid0 <- seq(0, N0, length.out = 400)
# Worker surplus before: between W0 and supply
polygon(
x = c(N_grid0, rev(N_grid0)),
y = c(rep(W0, length(N_grid0)), rev(W_supply(N_grid0))),
col = ws0_col, border = NA
)
# Firm surplus before: between demand0 and W0
polygon(
x = c(N_grid0, rev(N_grid0)),
y = c(W_d0(N_grid0), rep(W0, length(N_grid0))),
col = fs0_col, border = NA
)
# ---------------------------------------------------------
# Shade SURPLUSES AFTER demand shift (D')
# ---------------------------------------------------------
N_grid1 <- seq(0, N1, length.out = 400)
# Worker surplus after: between W1 and supply
polygon(
x = c(N_grid1, rev(N_grid1)),
y = c(rep(W1, length(N_grid1)), rev(W_supply(N_grid1))),
col = ws1_col, border = NA
)
# Firm surplus after: between demand1 and W1
polygon(
x = c(N_grid1, rev(N_grid1)),
y = c(W_d1(N_grid1), rep(W1, length(N_grid1))),
col = fs1_col, border = NA
)
# Re-draw curves on top so they remain crisp
lines(Ns, W, lwd=2)
lines(Nd0, W, lwd=2)
lines(Nd1, W, lwd=2, lty=2)
# Mark equilibria
points(N0, W0, pch=19)
text(N0, W0, "  (N0, W0)", pos=4)
points(N1, W1, pch=19)
text(N1, W1, "  (N1, W1)", pos=4)
# Wage lines (optional but helps interpret surplus)
abline(h = W0, lty = 3)
abline(h = W1, lty = 3)
# Legend (curves + shaded areas)
legend("topright",
legend=c("Supply: N=20W",
"Demand D: N=400-10W",
"Demand D': N=500-10W",
"Worker surplus (before)",
"Firm surplus (before)",
"Worker surplus (after)",
"Firm surplus (after)"),
lwd=c(2,2,2, NA, NA, NA, NA),
lty=c(1,1,2, NA, NA, NA, NA),
pch=c(NA, NA, NA, 15, 15, 15, 15),
pt.cex=1.8,
col=c("black","black","black",
ws0_col, fs0_col, ws1_col, fs1_col),
bty="n")
save_plot("prob1_competitive_surplus_shaded.png")
}
# =========================
# Problem 2: Payroll tax incidence
# =========================
{
W <- seq(0, 45, length.out = 400)
Ns <- 20*W
Nd <- 400 - 10*W
T <- 5
Nd_tax <- 400 - 10*(W + T)   # in terms of worker wage W
W_star <- 40/3; N_star <- 800/3
Ww <- 35/3; Nt <- 700/3
Wf <- Ww + T
plot(Ns, W, type="l", lwd=2,
xlab="Employment (N)", ylab="Worker wage (W)",
xlim=c(0, 450), ylim=c(0, 45),
main="Problem 2: Payroll Tax Incidence")
lines(Nd, W, lwd=2)
lines(Nd_tax, W, lwd=2, lty=2)
points(N_star, W_star, pch=19); text(N_star, W_star, "  A", pos=4)
points(Nt, Ww, pch=19); text(Nt, Ww, "  B", pos=4)
# show wedge at Nt
segments(Nt, Ww, Nt, Wf, lwd=2, lty=3)
text(Nt, (Ww+Wf)/2, "  T", pos=4)
legend("topright",
legend=c("Supply", "Demand (no tax)", "Demand with tax (shift down)"),
lwd=c(2,2,2), lty=c(1,1,2), bty="n")
save_plot("prob2_payroll_tax.png")
}
# =========================
# Problem 3: Competitive vs monopoly labour demand
# =========================
{
N <- seq(0, 30, length.out = 400)
VMP <- 500 - 20*N            # competitive VMP_N
MRP <- 200 - 200*N           # monopoly MRP_N (very steep here)
plot(N, VMP, type="l", lwd=2,
xlab="Employment (N)", ylab="Wage (W)",
xlim=c(0, 30), ylim=c(0, 520),
main="Problem 3: Competitive vs Monopoly Labour Demand")
lines(N, MRP, lwd=2, lty=2)
abline(h=200, lty=3)
# mark solutions at W=200
Nc <- 15
Nm <- 0
points(Nc, 200, pch=19); text(Nc, 200, "  N_C=15", pos=4)
points(Nm, 200, pch=19); text(Nm, 200, "  N_M=0", pos=4)
legend("topright",
legend=c("Competitive: VMP_N", "Monopoly: MRP_N"),
lwd=c(2,2), lty=c(1,2), bty="n")
save_plot("prob3_comp_vs_mono.png")
}
# =========================
# Problem 4: Monopsony diagram
# =========================
{
N <- seq(0, 90, length.out = 500)
S  <- 10 + 0.5*N
MC <- 10 + 1.0*N
VMP <- 100 - 1.0*N
NM <- 45; WM <- 32.5
NC <- 60; WC <- 40
plot(N, VMP, type="l", lwd=2,
xlab="Employment (N)", ylab="Wage (W)",
xlim=c(0, 90), ylim=c(0, 110),
main="Problem 4: Monopsony")
lines(N, S,  lwd=2)
lines(N, MC, lwd=2, lty=2)
points(NM, WM, pch=19); text(NM, WM, "  (N_M, W_M)", pos=4)
points(NC, WC, pch=19); text(NC, WC, "  (N_C, W_C)", pos=4)
legend("topright",
legend=c("Demand: VMP_N", "Supply: S=AC", "MC"),
lwd=c(2,2,2), lty=c(1,1,2), bty="n")
save_plot("prob4_monopsony.png")
}
# =========================
# Problem 5: Minimum wage under monopsony
# =========================
{
N <- seq(0, 90, length.out = 500)
S  <- 10 + 0.5*N
VMP <- 100 - 1.0*N
Wmin <- 50
Ncap <- (Wmin - 10)/0.5       # 80
# MC under min wage: flat at Wmin up to Ncap (sketch)
MCmin <- ifelse(N <= Ncap, Wmin, 10 + N)
Nmw <- 50  # from VMP=50
plot(N, VMP, type="l", lwd=2,
xlab="Employment (N)", ylab="Wage (W)",
xlim=c(0, 90), ylim=c(0, 110),
main="Problem 5: Minimum Wage under Monopsony")
lines(N, S, lwd=2)
lines(N, MCmin, lwd=2, lty=2)
abline(h=Wmin, lty=3)
points(Nmw, Wmin, pch=19); text(Nmw, Wmin, "  New choice", pos=4)
legend("topright",
legend=c("Demand: VMP_N", "Supply: S=AC", "MC under min wage", "Minimum wage"),
lwd=c(2,2,2,1), lty=c(1,1,2,3), bty="n")
save_plot("prob5_min_wage.png")
}
# =========================
# Problem 6: Perfect wage discrimination
# =========================
{
N <- seq(0, 90, length.out = 500)
S  <- 10 + 0.5*N
MC <- 10 + 1.0*N
VMP <- 100 - 1.0*N
NM <- 45; WM <- 32.5
ND <- 60; WD_supply <- 10 + 0.5*ND  # 40
plot(N, VMP, type="l", lwd=2,
xlab="Employment (N)", ylab="Wage (W)",
xlim=c(0, 90), ylim=c(0, 110),
main="Problem 6: Perfect Wage Discrimination vs Monopsony")
lines(N, S,  lwd=2)
lines(N, MC, lwd=2, lty=2)
points(NM, WM, pch=19); text(NM, WM, "  Monopsony", pos=4)
points(ND, WD_supply, pch=19); text(ND, WD_supply, "  Discrimination/Competitive", pos=4)
legend("topright",
legend=c("Demand: VMP_N", "Supply (also MC under discrimination)", "MC (single-wage monopsony)"),
lwd=c(2,2,2), lty=c(1,1,2), bty="n")
save_plot("prob6_discrimination.png")
}
# =========================
# Problem 7: Short-run vs long-run supply to the firm
# =========================
{
N <- seq(0, 120, length.out = 600)
Ssr <- 20 + 0.2*N
MCsr <- 20 + 0.4*N
VMP <- 100 - 2*N
Wlr <- 40
NSR <- 100/3
WSR <- 80/3
NLR <- 30
plot(N, VMP, type="l", lwd=2,
xlab="Employment (N)", ylab="Wage (W)",
xlim=c(0, 120), ylim=c(0, 110),
main="Problem 7: Short Run vs Long Run Labour Supply to the Firm")
lines(N, Ssr, lwd=2)
lines(N, MCsr, lwd=2, lty=2)
abline(h=Wlr, lty=3, lwd=2)
points(NSR, WSR, pch=19); text(NSR, WSR, "  Short run", pos=4)
points(NLR, Wlr, pch=19); text(NLR, Wlr, "  Long run", pos=4)
legend("topright",
legend=c("Demand: VMP_N", "Short-run supply", "Short-run MC", "Long-run supply (perfectly elastic)"),
lwd=c(2,2,2,2), lty=c(1,1,2,3), bty="n")
save_plot("prob7_short_long_run.png")
}
# =========================
# Helper: draw plot to screen AND save to PNG
# =========================
save_and_show <- function(filename, draw_fun,
width=1100, height=700, res=140) {
# 1) Draw to screen (RStudio Plots pane)
dev.new(noRStudioGD = TRUE)  # ensures a visible device
draw_fun()
# 2) Draw to file (guaranteed)
png(filename = filename, width = width, height = height, res = res)
draw_fun()
dev.off()
}
# =========================
# Problem 1: Competitive market (and demand shift) + surplus shading
# =========================
save_and_show("prob1_competitive_surplus_shaded.png", draw_fun = function() {
W <- seq(0, 45, length.out = 400)
Ns <- 20*W
Nd0 <- 400 - 10*W
Nd1 <- 500 - 10*W
# Equilibria
W0 <- 40/3; N0 <- 800/3
W1 <- 50/3; N1 <- 1000/3
# Inverse curves (W as a function of N)
W_supply <- function(N) N/20
W_d0     <- function(N) 40 - N/10
W_d1     <- function(N) 50 - N/10
# Semi-transparent colors
ws0_col <- adjustcolor("steelblue",  alpha.f = 0.25)  # worker surplus before
fs0_col <- adjustcolor("darkorange", alpha.f = 0.25)  # firm surplus before
ws1_col <- adjustcolor("royalblue",  alpha.f = 0.25)  # worker surplus after
fs1_col <- adjustcolor("orangered3", alpha.f = 0.25)  # firm surplus after
# Base plot
plot(Ns, W, type="l", lwd=2,
xlab="Employment (N)", ylab="Wage (W)",
xlim=c(0, 520), ylim=c(0, 55),
main="Competitive Labour Market: Worker & Firm Surplus (Before/After Demand Shift)")
# Demand curves
lines(Nd0, W, lwd=2)
lines(Nd1, W, lwd=2, lty=2)
# ----- Shade BEFORE (D) -----
N_grid0 <- seq(0, N0, length.out = 400)
polygon(
x = c(N_grid0, rev(N_grid0)),
y = c(rep(W0, length(N_grid0)), rev(W_supply(N_grid0))),
col = ws0_col, border = NA
)
polygon(
x = c(N_grid0, rev(N_grid0)),
y = c(W_d0(N_grid0), rep(W0, length(N_grid0))),
col = fs0_col, border = NA
)
# ----- Shade AFTER (D') -----
N_grid1 <- seq(0, N1, length.out = 400)
polygon(
x = c(N_grid1, rev(N_grid1)),
y = c(rep(W1, length(N_grid1)), rev(W_supply(N_grid1))),
col = ws1_col, border = NA
)
polygon(
x = c(N_grid1, rev(N_grid1)),
y = c(W_d1(N_grid1), rep(W1, length(N_grid1))),
col = fs1_col, border = NA
)
# Re-draw curves on top
lines(Ns, W, lwd=2)
lines(Nd0, W, lwd=2)
lines(Nd1, W, lwd=2, lty=2)
# Equilibrium points
points(N0, W0, pch=19); text(N0, W0, "  (N0, W0)", pos=4)
points(N1, W1, pch=19); text(N1, W1, "  (N1, W1)", pos=4)
# Wage reference lines
abline(h = W0, lty = 3)
abline(h = W1, lty = 3)
legend("topright",
legend=c("Supply: N=20W",
"Demand D: N=400-10W",
"Demand D': N=500-10W",
"Worker surplus (before)",
"Firm surplus (before)",
"Worker surplus (after)",
"Firm surplus (after)"),
lwd=c(2,2,2, NA, NA, NA, NA),
lty=c(1,1,2, NA, NA, NA, NA),
pch=c(NA, NA, NA, 15, 15, 15, 15),
pt.cex=1.6,
col=c("black","black","black",
ws0_col, fs0_col, ws1_col, fs1_col),
bty="n")
})
# =========================
# Problem 2: Payroll tax incidence
