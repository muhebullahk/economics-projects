    mean(x)})
ans <- cbind(ans, ans2)
colnames(ans) <- c("Real per capita GDP (thousands of dollars)", 
                   "Real per capita GDP (logs)")
rownames(ans) <- c("First quintile",
                   "Second quintile",
                   "Third quintile",
                   "Fourth quintile",
                   "Fifth quintile")
@ 
