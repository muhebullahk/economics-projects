\begin{center}
\begin{minipage}{.45\textwidth}
<<det6, echo=FALSE, fig.height=6.5, fig.width=10>>=
plot(lit, g,
     main="Economic growth versus literacy",
     xlab="Literacy rate (percent)",
     ylab="Average economic growth (percent)",
