% -------------------------------------------------------
% Theorem-like environments
\newtheorem{theorem}{Theorem}[section]
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{corollary}[theorem]{Corollary}
\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{example}[theorem]{Example}
\newtheorem{exercise}{Exercise}
\theoremstyle{remark}
\newtheorem*{remark}{Remark}
\newtheorem*{note}{Note}

% -------------------------------------------------------
% Common economics notation
\newcommand{\E}{\mathbb{E}}          % Expectations operator
\newcommand{\R}{\mathbb{R}}          % Real numbers
\newcommand{\N}{\mathbb{N}}          % Natural numbers
\newcommand{\pd}[2]{\frac{\partial #1}{\partial #2}}
\newcommand{\pdd}[2]{\frac{\partial^2 #1}{\partial #2^2}}

% Micro
\newcommand{\MRS}{\mathrm{MRS}}
\newcommand{\MRT}{\mathrm{MRT}}
\newcommand{\MU}{\mathrm{MU}}
\newcommand{\MC}{\mathrm{MC}}
\newcommand{\MR}{\mathrm{MR}}
\newcommand{\MP}{\mathrm{MP}}
\newcommand{\AC}{\mathrm{AC}}
\newcommand{\AVC}{\mathrm{AVC}}
\newcommand{\AFC}{\mathrm{AFC}}
\newcommand{\TR}{\mathrm{TR}}
\newcommand{\TC}{\mathrm{TC}}
\newcommand{\VC}{\mathrm{VC}}
\newcommand{\FC}{\mathrm{FC}}
\newcommand{\CS}{\mathrm{CS}}
\newcommand{\PS}{\mathrm{PS}}
\newcommand{\DWL}{\mathrm{DWL}}

% Macro / Metrics
